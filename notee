    <!-- 🟢 NEW: WEBSITE TRAFFIC TRACKER (Google Sheets) -->
    <!-- ============================================== -->
    <script>
        async function trackVisitor() {
            try {
                // User ka IP aur Location fetch karein
                const ipRes = await fetch('https://ipapi.co/json/');
                const ipData = await ipRes.json();
                
                const location = `${ipData.city || 'Unknown'}, ${ipData.region || 'Unknown'}, ${ipData.country_name || 'Unknown'}`;
                const deviceInfo = navigator.userAgent;
                const screen = `${window.screen.width}x${window.screen.height}`;
                const time = new Date().toISOString();
                const referrer = document.referrer || "Direct";
                const page = window.location.href;

                const payload = {
                    Timestamp: time,
                    IP: ipData.ip || 'N/A',
                    Location: location,
                    Device: deviceInfo,
                    Screen: screen,
                    Referrer: referrer,
                    Page: page
                };

                // ⚠️ YAHAN APNA GOOGLE APPS SCRIPT URL PASTE KAREIN ⚠️
                const API_URL = "PASTE_YOUR_GOOGLE_APPS_SCRIPT_WEB_APP_URL_HERE";

                await fetch(API_URL, {
                    method: 'POST',
                    mode: 'no-cors', // CORS error se bachne ke liye
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                
                console.log("Visitor tracked successfully!");
            } catch (e) {
                console.log("Tracking failed (expected on localhost or blocked):", e);
            }
        }

        // Page load par turant track karein
        trackVisitor();
    </script>

